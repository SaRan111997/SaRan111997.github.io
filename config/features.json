{
  "theme": {
    "default": "dark",
    "allowToggle": true,
    "respectSystemPreference": true
  },
  "animations": {
    "scrollReveal": true,
    "heroTyping": true,
    "cursorGlow": true,
    "reducedMotionFallback": true
  },
  "sections": {
    "hero": true,
    "about": true,
    "skills": true,
    "experience": true,
    "projects": true,
    "contact": true,
    "blog": false,
    "chatbot": false
  },
  "i18n": {
    "enabled": false,
    "default": "en",
    "supported": ["en"]
  },
  "email": {
    "provider": "web3forms",
    "endpoint": "a2308015-eac7-4dd5-ab98-8c25b9b5ae64",
    "honeypotField": "website",
    "subject": "New portfolio contact — {name}",
    "successMessage": "Thanks — I'll get back to you within 24 hours.",
    "errorMessage": "Something went wrong. Please try again or reach out on LinkedIn."
  },
  "analytics": {
    "enabled": false,
    "provider": "plausible",
    "domain": ""
  }
}
